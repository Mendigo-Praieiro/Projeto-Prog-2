<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="320.0" prefWidth="400.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="GUI.SalaController">
   <children>
      <Label layoutX="107.0" layoutY="20.0" text="Cadastro de Sala">
         <font>
            <Font name="System Bold" size="20.0" />
         </font>
      </Label>
      
      <Label layoutX="35.0" layoutY="70.0" text="Número da Sala:" />
      <TextField fx:id="txtNumero" layoutX="35.0" layoutY="90.0" prefWidth="330.0" />
      
      <Label layoutX="35.0" layoutY="135.0" text="Bloco / Prédio:" />
      <TextField fx:id="txtBloco" layoutX="35.0" layoutY="155.0" prefWidth="330.0" />
      
      <Label layoutX="35.0" layoutY="200.0" text="Capacidade Máxima:" />
      <TextField fx:id="txtCapacidade" layoutX="35.0" layoutY="220.0" prefWidth="330.0" />
      
      <Button fx:id="btnSalvar" layoutX="285.0" layoutY="265.0" mnemonicParsing="false" onAction="#salvarSala" prefWidth="80.0" text="Salvar" />
   </children>
</AnchorPane>