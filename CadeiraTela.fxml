<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<AnchorPane prefHeight="380.0" prefWidth="400.0" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="GUI.CadeiraController">
   <children>
      <Label layoutX="96.0" layoutY="20.0" text="Cadastro de Cadeira">
         <font>
            <Font name="System Bold" size="20.0" />
         </font>
      </Label>
      
      <Label layoutX="35.0" layoutY="65.0" text="Código da Cadeira:" />
      <TextField fx:id="txtCodigo" layoutX="35.0" layoutY="85.0" prefWidth="330.0" />
      
      <Label layoutX="35.0" layoutY="130.0" text="Nome da Disciplina:" />
      <TextField fx:id="txtNome" layoutX="35.0" layoutY="150.0" prefWidth="330.0" />
      
      <Label layoutX="35.0" layoutY="195.0" text="Carga Horária (Ex: 60):" />
      <TextField fx:id="txtCargaHoraria" layoutX="35.0" layoutY="215.0" prefWidth="330.0" />
      
      <Label layoutX="35.0" layoutY="260.0" text="Tipo (OBRIGATORIA / ELETIVA):" />
      <TextField fx:id="txtTipo" layoutX="35.0" layoutY="280.0" prefWidth="330.0" placeholderString="OBRIGATORIA" />
      
      <Button fx:id="btnSalvar" layoutX="285.0" layoutY="325.0" mnemonicParsing="false" onAction="#salvarCadeira" prefWidth="80.0" text="Salvar" />
   </children>
</AnchorPane>